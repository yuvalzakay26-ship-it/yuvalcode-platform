# ==========================================
# Environment Configuration (.env.example)
# ==========================================
# Copy this file to .env.local (or .env) for local development.
# In production, set these variables in your hosting provider's dashboard.

# YouTube Data API v3 — restrict the key to your domain in Google Cloud Console
VITE_YOUTUBE_API_KEY=
VITE_YOUTUBE_CHANNEL_ID=

# Contact form endpoint — REQUIRED for the contact form to work.
# Recommended: Formspree (https://formspree.io) — create a form, paste the endpoint here.
# Example: https://formspree.io/f/abcdwxyz
VITE_CONTACT_ENDPOINT=
